SEMANTIC_INPUT_LIMIT=24
LLM_INPUT_LIMIT=12
FINAL_RESULT_LIMIT=10
EXCERPT_CHAR_LIMIT=1000
AGENTIC_SEARCH_ENABLED=true
AGENTIC_MAX_ROUNDS=2
AGENTIC_ACTIONS_PER_ROUND=4
AGENTIC_ACTION_LIMIT=8

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16

REQUIRE_BOOTSTRAP_INDEXES=true
